# Copy to .env if you need to override defaults for local (non-Docker) runs.
# Milestone 1 + Milestone 2 + Milestone 3 scope. AI provider keys for RAG
# chat are added in Milestone 4.

# apps/api
DATABASE_URL=postgresql://knowledgehub:knowledgehub@localhost:5432/knowledgehub
QDRANT_URL=http://localhost:6333
WEB_ORIGIN=http://localhost:3000

# JWT_SECRET: the default in app/core/config.py ("dev-secret-change-me") is
# deliberately named so it can't be mistaken for a real secret. Set a real
# random value here (e.g. `openssl rand -hex 32`) for anything beyond local
# development -- ENV must also be set to "production" for the session
# cookie to be marked Secure (see apps/api/app/api/v1/routes/auth.py).
JWT_SECRET=dev-secret-change-me
ENV=development

# Milestone 3 -- document upload & ingestion. Defaults are fine for local
# dev; shown here so they're discoverable without reading config.py.
# STORAGE_DIR=./storage
# MAX_UPLOAD_MB=25
# CHUNK_TOKEN_SIZE=500
# CHUNK_OVERLAP=60
# QDRANT_COLLECTION=document_chunks_v1
# EMBEDDING_DIMENSION=384
# EMBEDDING_PROVIDER=local

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:8000
